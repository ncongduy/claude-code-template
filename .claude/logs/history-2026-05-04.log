"\\\"$CLAUDE_PROJECT_DIR\\\"/.claude/hooks/log-history.sh Notification\" }\n        ]\n      }\n    ],\n    \"Stop\": [\n      {\n        \"matcher\": \"\",\n        \"hooks\": [\n          { \"type\": \"command\", \"command\": \"\\\"$CLAUDE_PROJECT_DIR\\\"/.claude/hooks/notify-complete.sh\" },\n          { \"type\": \"command\", \"command\": \"\\\"$CLAUDE_PROJECT_DIR\\\"/.claude/hooks/log-history.sh Stop\" }\n        ]\n      }\n    ]\n  }\n}\n","numLines":54,"startLine":1,"totalLines":54}},"tool_use_id":"toolu_01KAPYd9gVpu1y2a5bBABqwA","duration_ms":1}
